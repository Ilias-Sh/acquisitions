# ============================================
# Environment Variables — copy to .env and fill in your values
# ============================================

# Node environment: "development" or "production"
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# Winston log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# ============================================
# Database (Neon PostgreSQL)
# ============================================

# Get this from your Neon project dashboard → Connection string
# Use a pooled endpoint in production
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ============================================
# Security
# ============================================

# JWT signing secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Arcjet API key — get yours from https://app.arcjet.com
ARCJET_KEY=ajkey_yourarcjetkeyhere

# ============================================
# Neon Local (Docker dev only)
# Only needed when running npm run dev:docker
# Get these from https://console.neon.tech/app/settings/api-keys
# ============================================

NEON_API_KEY=your_neon_api_key_here
NEON_PROJECT_ID=your_neon_project_id_here
PARENT_BRANCH_ID=your_neon_parent_branch_id_here